.picker { white-space: nowrap; padding: var(--space-sm) 0; }
.chip { display: inline-block; padding: var(--space-sm) var(--space-md); margin-right: var(--space-sm); border-radius: var(--radius-round); font-size: var(--font-sm); background: var(--color-divider); }
.chip.active { background: var(--color-primary); color: #fff; }
