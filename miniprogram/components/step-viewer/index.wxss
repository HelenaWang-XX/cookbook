.step { display: flex; gap: var(--space-md); padding-bottom: var(--space-md); }
.step-indicator { display: flex; flex-direction: column; align-items: center; }
.step-circle { width: 48rpx; height: 48rpx; border-radius: 50%; background: var(--color-primary); color: #fff; font-size: var(--font-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-line { width: 2rpx; flex: 1; background: var(--color-border); margin-top: var(--space-xs); }
.step-body { flex: 1; padding-top: var(--space-xs); }
.step-desc { font-size: var(--font-sm); color: var(--color-text-primary); line-height: 1.8; display: block; }
.step-image { width: 100%; border-radius: var(--radius-md); margin-top: var(--space-sm); background: var(--color-divider); max-height: 400rpx; }
