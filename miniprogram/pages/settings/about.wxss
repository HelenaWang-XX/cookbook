.page { min-height: 100vh; background: var(--color-bg); padding-top: 120rpx; }
.logo { font-size: 96rpx; }
.app-name { font-size: var(--font-xxl); font-weight: 700; margin-top: var(--space-md); }
.version { font-size: var(--font-sm); color: var(--color-text-hint); margin-top: var(--space-xs); }
.desc-card { margin-top: var(--space-xl); background: var(--color-bg-white); border-radius: var(--radius-md); padding: var(--space-lg); width: 80%; }
.desc { font-size: var(--font-sm); color: var(--color-text-secondary); line-height: 2; }
