.page { min-height: 100vh; background: var(--color-bg); padding: var(--space-md); }
.card { background: var(--color-bg-white); border-radius: var(--radius-md); padding: var(--space-lg); margin-bottom: var(--space-md); }
.title { font-size: var(--font-lg); font-weight: 600; display: block; margin-bottom: var(--space-sm); }
.desc { font-size: var(--font-sm); color: var(--color-text-hint); line-height: 1.6; display: block; }

.input-wrap { display: flex; align-items: center; margin-top: var(--space-md); background: var(--color-bg); border-radius: var(--radius-md); padding: var(--space-sm); }
.url-input { flex: 1; font-size: var(--font-sm); padding: var(--space-xs); }
.paste-btn { font-size: var(--font-sm); color: var(--color-primary); padding: var(--space-xs) var(--space-sm); flex-shrink: 0; }

.error-msg { display: block; font-size: var(--font-sm); color: var(--color-danger); margin-top: var(--space-sm); }

.extract-btn { width: 100%; margin-top: var(--space-lg); background: var(--color-primary); color: #fff; border: none; border-radius: var(--radius-md); font-size: var(--font-md); padding: var(--space-sm) 0; }
.offline-hint { display: block; font-size: var(--font-xs); color: var(--color-warning); margin-top: var(--space-sm); text-align: center; }
