.page { min-height: 100vh; background: var(--color-bg); }
.header { padding: var(--space-md); font-size: var(--font-sm); color: var(--color-text-hint); background: #FFF9E6; }
.form-section { background: var(--color-bg-white); padding: var(--space-md); margin-bottom: var(--space-md); }
.label { font-size: var(--font-sm); color: var(--color-text-secondary); display: block; margin-top: var(--space-sm); margin-bottom: var(--space-xs); }
.input { width: 100%; font-size: var(--font-md); padding: var(--space-sm); background: var(--color-bg); border-radius: var(--radius-sm); box-sizing: border-box; }
.picker-val { font-size: var(--font-md); padding: var(--space-sm); background: var(--color-bg); border-radius: var(--radius-sm); }
.edit-row { margin-top: var(--space-xs); }
.step-num { font-size: var(--font-sm); color: var(--color-primary); font-weight: 600; }
.step-input { width: 100%; font-size: var(--font-sm); padding: var(--space-xs); margin-top: 4rpx; }
.save-bar { padding: var(--space-md); }
.save-btn { width: 100%; background: var(--color-primary); color: #fff; border: none; border-radius: var(--radius-md); font-size: var(--font-lg); padding: var(--space-sm) 0; }
