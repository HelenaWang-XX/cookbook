.page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 封面 */
.cover-section {
  text-align: center;
  padding: var(--space-md);
}
.cover-preview {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-md);
  background: var(--color-divider);
}
.cover-placeholder {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--color-border);
}
.placeholder-icon {
  font-size: 64rpx;
}
.placeholder-text {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
}
.cover-remove {
  font-size: var(--font-xs);
  color: var(--color-danger);
  margin-top: var(--space-xs);
  display: inline-block;
}

/* 表单区域 */
.form-section {
  background: var(--color-bg-white);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--space-xs);
  margin-top: var(--space-sm);
}
.section-label:first-child {
  margin-top: 0;
}
.add-link {
  font-size: var(--font-sm);
  color: var(--color-primary);
}
.form-input {
  width: 100%;
  font-size: var(--font-md);
  padding: var(--space-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}
.flex-1 {
  flex: 1;
}
.form-textarea {
  width: 100%;
  font-size: var(--font-md);
  padding: var(--space-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
  min-height: 120rpx;
}
.picker-value {
  font-size: var(--font-md);
  padding: var(--space-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  color: var(--color-text-primary);
}

/* 食材行 */
.ingredient-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}
.row-num {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  width: 32rpx;
  text-align: center;
}
.row-delete {
  font-size: var(--font-sm);
  color: var(--color-danger);
  padding: var(--space-xs);
}

/* 步骤行 */
.step-row {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  padding: var(--space-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}
.step-order {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-primary);
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}
.step-content {
  flex: 1;
}
.step-textarea {
  width: 100%;
  font-size: var(--font-sm);
  min-height: 80rpx;
}
.step-image-row {
  margin-top: var(--space-xs);
}
.step-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: var(--radius-sm);
  background: var(--color-divider);
}
.step-add-img {
  font-size: var(--font-xs);
  color: var(--color-primary);
  padding: var(--space-xs) 0;
}

/* 保存按钮 */
.save-bar {
  padding: var(--space-md);
}
.save-btn {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  padding: var(--space-sm) 0;
}
