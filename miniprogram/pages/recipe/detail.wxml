<!-- 菜谱详情页 -->
<scroll-view class="page" scroll-y wx:if="{{recipe}}">

  <!-- 封面图 -->
  <image
    class="cover-image"
    src="{{recipe.coverImagePath || '/assets/default-cover.png'}}"
    mode="aspectFill"
    wx:if="{{recipe.coverImagePath}}"
  />

  <!-- 基本信息 -->
  <view class="info-card">
    <text class="dish-name">{{recipe.name}}</text>
    <view class="dish-meta">
      <text class="meta-chip">{{categoryLabel}}</text>
      <text class="meta-chip">{{difficultyLabel}}</text>
      <text class="meta-chip" wx:if="{{durationText}}">⏱ {{durationText}}</text>
      <text class="meta-chip">{{recipe.servings}}人份</text>
    </view>
    <view wx:if="{{recipe.tags.length > 0}}" class="dish-tags">
      <text class="tag" wx:for="{{recipe.tags}}" wx:key="*this">#{{item}}</text>
    </view>
    <view wx:if="{{recipe.sourceUrl}}" class="source-link">
      <text>来源：</text>
      <text class="link">{{recipe.sourceName || recipe.sourceUrl}}</text>
    </view>
  </view>

  <!-- 食材列表 -->
  <view class="section">
    <view class="section-title">
      <text>🥬 食材清单</text>
      <text class="servings">（{{recipe.servings}}人份）</text>
    </view>
    <ingredient-list ingredients="{{recipe.ingredients}}" />
  </view>

  <!-- 步骤 -->
  <view class="section">
    <view class="section-title">📝 烹饪步骤</view>
    <step-viewer steps="{{recipe.steps}}" />
  </view>

  <!-- 备注 -->
  <view class="section" wx:if="{{recipe.notes}}">
    <view class="section-title">📌 备注</view>
    <view class="notes-text">{{recipe.notes}}</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-area-bottom">
    <button
      class="bar-btn {{isInShoppingList ? 'bar-btn-remove' : 'bar-btn-cart'}}"
      bindtap="toggleShoppingList"
    >
      {{isInShoppingList ? '移出购物清单' : '🛒 加入购物清单'}}
    </button>
    <button class="bar-btn bar-btn-edit" bindtap="editRecipe">✏️ 编辑</button>
    <button class="bar-btn bar-btn-delete" bindtap="deleteRecipe">🗑</button>
  </view>

  <view style="height: 140rpx;"></view>
</scroll-view>

<!-- 错误 / 加载状态 -->
<view wx:elif="{{error}}" class="flex-center" style="height:100vh;">
  <text>{{error}}</text>
</view>
<view wx:else class="flex-center" style="height:100vh;">
  <text>加载中…</text>
</view>
