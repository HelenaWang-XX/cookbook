<!-- 我的页面 -->
<scroll-view class="page" scroll-y>

  <!-- 头部统计 -->
  <view class="header">
    <view class="header-stat">
      <text class="header-num">{{recipeCount}}</text>
      <text class="header-label">道菜谱</text>
    </view>
    <view class="header-divider"></view>
    <view class="header-stat">
      <text class="header-num">{{shoppingListCount}}</text>
      <text class="header-label">待购清单</text>
    </view>
  </view>

  <!-- 存储指示器 -->
  <view class="storage-bar" bindtap="goToStorageManage">
    <storage-indicator ratio="{{storageRatio}}" />
  </view>

  <!-- 功能入口 -->
  <view class="menu-section">
    <view class="menu-title">功能</view>
    <view class="menu-item" bindtap="goToShoppingList">
      <text class="menu-icon">🛒</text>
      <text class="menu-label">购物清单</text>
      <text class="menu-badge" wx:if="{{shoppingListCount > 0}}">{{shoppingListCount}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAdd">
      <text class="menu-icon">✏️</text>
      <text class="menu-label">添加菜谱</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">数据</view>
    <view class="menu-item" bindtap="goToStorageManage">
      <text class="menu-icon">💾</text>
      <text class="menu-label">存储管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAliasManage">
      <text class="menu-icon">🏷️</text>
      <text class="menu-label">食材别名管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">其他</view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view style="height: 120rpx;"></view>
</scroll-view>
