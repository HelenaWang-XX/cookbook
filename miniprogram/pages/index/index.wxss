.page {
  height: 100vh;
  padding-bottom: 100rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  padding: var(--space-md);
  gap: var(--space-sm);
}
.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: var(--space-lg) var(--space-sm);
}
.stat-num {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
}
.stat-icon {
  font-size: var(--font-xxl);
}
.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: var(--space-sm);
  padding: 0 var(--space-md);
  margin-bottom: var(--space-md);
}
.action-btn {
  flex: 1;
  font-size: var(--font-sm);
  border-radius: var(--radius-round);
  padding: var(--space-sm) 0;
  text-align: center;
  border: none;
  line-height: 1.5;
}
.action-primary {
  background: var(--color-primary);
  color: #fff;
}
.action-outline {
  background: var(--color-bg-white);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

/* 分类滚动 */
.section {
  margin-bottom: var(--space-md);
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md);
  padding-bottom: var(--space-sm);
}
.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
}
.section-more {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}
.category-scroll {
  white-space: nowrap;
}
.category-list {
  display: inline-flex;
  gap: var(--space-sm);
  padding: 0 var(--space-md);
}
.category-chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-bg-white);
  border-radius: var(--radius-round);
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-border);
}
.chip-icon {
  font-size: var(--font-lg);
}
.chip-label {
  font-size: var(--font-sm);
  font-weight: 500;
}
.chip-count {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}

/* 菜谱列表 */
.recipe-list {
  padding: 0 var(--space-md);
}
.recipe-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: var(--space-sm);
  margin-bottom: var(--space-sm);
}
.recipe-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: var(--radius-sm);
  background: var(--color-divider);
  flex-shrink: 0;
}
.recipe-info {
  flex: 1;
  overflow: hidden;
}
.recipe-name {
  font-size: var(--font-md);
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.recipe-meta {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}
.meta-tag {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  background: var(--color-divider);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
}
.meta-time {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}
