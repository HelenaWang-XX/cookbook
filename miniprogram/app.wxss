/** 全局样式变量 */
page {
  --color-primary: #07C160;
  --color-primary-dark: #06AD56;
  --color-danger: #FA5151;
  --color-warning: #FFC300;
  --color-text-primary: #191919;
  --color-text-secondary: #666666;
  --color-text-hint: #999999;
  --color-bg: #F6F6F6;
  --color-bg-white: #FFFFFF;
  --color-border: #E5E5E5;
  --color-divider: #F0F0F0;

  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --radius-round: 9999rpx;

  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: var(--font-md);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/** 通用工具类 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/** 通用卡片 */
.card {
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  margin: var(--space-md);
  padding: var(--space-md);
}

/** 通用按钮 */
.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-xl);
}

.btn-outline {
  background-color: transparent;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-xl);
}

.btn-danger {
  background-color: var(--color-danger);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-xl);
}

/** 分类标签颜色 */
.category-meat { color: #E85D3F; }
.category-vegetarian { color: #4CAF50; }
.category-seafood { color: #2196F3; }
.category-soup { color: #FF9800; }
.category-staple { color: #8D6E63; }
.category-dessert { color: #E91E63; }

.bg-category-meat { background-color: #FFF0EC; }
.bg-category-vegetarian { background-color: #E8F5E9; }
.bg-category-seafood { background-color: #E3F2FD; }
.bg-category-soup { background-color: #FFF3E0; }
.bg-category-staple { background-color: #EFEBE9; }
.bg-category-dessert { background-color: #FCE4EC; }
